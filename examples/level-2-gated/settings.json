{
  "_comment": "Level 2: Manifest + Gates. Blocks tools until Tier 1 is read.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .agent/hooks/on_session_start.py",
            "timeout": 60000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .agent/hooks/gate_check.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .agent/hooks/on_prompt_submit.py",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
